<%
  var siteTitle = theme.title || config.title || '深海樱花·祁煜';
  var currentTitle = page.title ? page.title + ' | ' + siteTitle : siteTitle;
  var rawDescription = page.description || page.excerpt || theme.description || config.description || '';
  var cleanDescription = String(rawDescription).replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim().slice(0, 160);
  var canonicalPath = page.path ? url_for(page.path) : url_for('/');
%>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title><%- currentTitle %></title>
<meta name="description" content="<%- cleanDescription %>">
<meta name="author" content="<%- theme.author || config.author || '' %>">
<link rel="canonical" href="<%- canonicalPath %>">
<meta property="og:type" content="<%- page.layout === 'post' ? 'article' : 'website' %>">
<meta property="og:title" content="<%- currentTitle %>">
<meta property="og:description" content="<%- cleanDescription %>">
<meta property="og:site_name" content="<%- siteTitle %>">
